PUBLIC_SITE_URL=https://polyglow.realrip.com

# Optional first-party asset origin for remote image URLs.
# PUBLIC_ASSET_BASE_URL=https://assets.example.com

# Optional Google Tag Manager. Disabled unless explicitly enabled.
# PUBLIC_GTM_ENABLED=false
# PUBLIC_GTM_ID=GTM-XXXXXXX

# Optional Google AdSense. Disabled unless explicitly enabled.
# PUBLIC_ADSENSE_ENABLED=false
# PUBLIC_ADSENSE_CLIENT_ID=ca-pub-0000000000000000

# Optional x402 metadata widget. Disabled unless explicitly enabled.
# This only publishes payment metadata on static builds; HTTP 402 enforcement
# requires a server middleware integration.
# Solana mainnet uses a base58 wallet address as the receiving address.
# PUBLIC_X402_ENABLED=false
# PUBLIC_X402_PAY_TO=YourSolanaWalletAddress
# PUBLIC_X402_NETWORK=solana:5eykt4UsFv8P8NJdTREpY1vzqKqZKvdp
# PUBLIC_X402_PRICE=$0.01
# PUBLIC_X402_DESCRIPTION=Voluntary x402 payment support for Polyglow content.
# PUBLIC_X402_FACILITATOR_URL=https://your-solana-mainnet-facilitator.example
