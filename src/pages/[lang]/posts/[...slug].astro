---
import { getCollection, render } from "astro:content"
import Layout from "@/layouts/main.astro"
import OptimizedPicture from "@/components/features/OptimizedPicture.astro"
import ProseContent from "@/components/layout/ProseContent.astro"
import PostCardGrid from "@/components/lists/PostCardGrid.astro"
import TableOfContents from "@/components/navigation/TableOfContents.astro"
import { articleJsonLd } from "@/utils/structured-data"
import { DEFAULT_LOCALE, LOCALES, type Locale } from "@/config/locales"
import {
  getPostsForLocale,
  postCategorySlug,
  postPath,
  postSlug,
  postTagSlugs,
  postUrl,
  type PostEntry,
} from "@/utils/posts"
import { selectRelatedPosts } from "@/utils/post-navigation"
import { getAuthor } from "@/utils/content"
import { getCategory, getTag } from "@/config/taxonomy"
import { SITE_CONFIG } from "@/config/site"
import { t } from "@/utils/translations"
import { normalizeMetaDescription } from "@/utils/seo"
import { postLocaleAlternates } from "@/utils/alternates"
import type { TocHeading } from "@/utils/headings"
import authorImage from "@/assets/author.avif"

type PostFallbackRedirectProps = {
  lang: Locale
  redirectTo: string
  slug: string
}

type PostPageProps = { post: PostEntry } | PostFallbackRedirectProps

function isPostFallbackRedirect(
  props: PostPageProps
): props is PostFallbackRedirectProps {
  return "redirectTo" in props
}

export async function getStaticPaths() {
  const posts = await getCollection("post", (entry) => !entry.data.draft)
  const localizedPostKeys = new Set(
    posts.map((post) => `${post.data.locale}:${postSlug(post)}`)
  )
  const postPaths = posts.map((post) => ({
    params: { lang: post.data.locale, slug: postSlug(post) },
    props: { post },
  }))
  const fallbackRedirectPaths = posts
    .filter((post) => post.data.locale === DEFAULT_LOCALE)
    .flatMap((post) => {
      const slug = postSlug(post)
      return LOCALES.filter(
        (locale) =>
          locale !== DEFAULT_LOCALE && !localizedPostKeys.has(`${locale}:${slug}`)
      ).map((locale) => ({
        params: { lang: locale, slug },
        props: { lang: locale, slug, redirectTo: postUrl(post) },
      }))
    })

  return [...postPaths, ...fallbackRedirectPaths]
}

const props = Astro.props as PostPageProps
const fallbackRedirect = isPostFallbackRedirect(props) ? props : undefined
const articleProps = isPostFallbackRedirect(props) ? undefined : props
const fallbackPath = fallbackRedirect ? `/posts/${fallbackRedirect.slug}/` : "/"
const fallbackCanonical = fallbackRedirect
  ? `${SITE_CONFIG.url}${fallbackRedirect.redirectTo}`
  : undefined

async function getArticlePageData(post: PostEntry) {
  const { Content: RenderedContent, headings } = await render(post)
  const author = await getAuthor(post.data.locale, post.data.authors[0])
  const path = postPath(post)
  const alternates = postLocaleAlternates(post)
  const posts = await getPostsForLocale(post.data.locale)
  const relatedPosts = selectRelatedPosts(posts, post, 3)
  const categorySlug = postCategorySlug(post)
  const category = getCategory(categorySlug)
  const categoryLabel = category?.labelByLocale[post.data.locale] ?? categorySlug
  const tags = postTagSlugs(post)
    .map((tag) => getTag(tag))
    .filter((tag): tag is NonNullable<ReturnType<typeof getTag>> => Boolean(tag))
  const tagLabels = tags.map((tag) => tag.labelByLocale[post.data.locale])
  const metaDescription =
    post.data.seoDescription ??
    (post.data.locale === "en"
      ? normalizeMetaDescription(
          post.data.description,
          [
            `It adds context for ${categoryLabel.toLowerCase()} readers.`,
            "It supports later review.",
            "Inside RealRip.",
          ]
        )
      : post.data.description)
  const dateFormatter = new Intl.DateTimeFormat(post.data.locale, {
    month: "short",
    day: "numeric",
    year: "numeric",
  })
  const publishedLabel = dateFormatter.format(post.data.pubDate)
  const modifiedLabel = dateFormatter.format(
    post.data.updatedDate ?? post.data.pubDate
  )
  const publishedText = t(post.data.locale, "post.publishedAt")
  const modifiedText = t(post.data.locale, "post.modifiedAt")
  const tocHeadings = headings
    .filter((heading) => heading.depth === 2 || heading.depth === 3)
    .map((heading) => ({
      depth: heading.depth as 2 | 3,
      text: heading.text,
      slug: heading.slug,
    })) satisfies TocHeading[]
  const jsonLd = articleJsonLd({
    lang: post.data.locale,
    path,
    title: post.data.seoTitle ?? post.data.title,
    description: metaDescription,
    image: post.data.heroImage,
    pubDate: post.data.pubDate,
    updatedDate: post.data.updatedDate,
    authors: [
      {
        name: author?.data.name ?? SITE_CONFIG.name,
        url: `${SITE_CONFIG.url}/${post.data.locale}/author/`,
      },
    ],
  })

  return {
    post,
    Content: RenderedContent,
    author,
    path,
    alternates,
    relatedPosts,
    categorySlug,
    categoryLabel,
    tagLabels,
    metaDescription,
    publishedLabel,
    modifiedLabel,
    publishedText,
    modifiedText,
    tocHeadings,
    jsonLd,
  }
}

const article = articleProps
  ? await getArticlePageData(articleProps.post)
  : undefined
const ArticleContent = article?.Content
---

{
  fallbackRedirect ? (
    <Layout
      lang={fallbackRedirect.lang}
      path={fallbackPath}
      title={t(fallbackRedirect.lang, "fallback.title")}
      description={t(fallbackRedirect.lang, "fallback.message")}
      canonicalUrl={fallbackCanonical}
      refreshTo={fallbackRedirect.redirectTo}
      noindex
      jsonLd={false}
    >
      <section
        class="mx-auto flex min-h-[45vh] w-full max-w-2xl flex-col items-center justify-center gap-5 px-4 py-16 text-center"
        data-polyglow-fallback-redirect
        data-pagefind-ignore
      >
        <h1 class="text-2xl font-semibold tracking-normal text-foreground">
          {t(fallbackRedirect.lang, "fallback.title")}
        </h1>
        <p class="text-sm leading-7 text-muted-foreground">
          {t(fallbackRedirect.lang, "fallback.message")}
        </p>
        <a
          href={fallbackRedirect.redirectTo}
          rel="canonical"
          class="inline-flex min-h-10 items-center justify-center rounded-lg bg-primary px-4 py-2 text-sm font-semibold text-primary-foreground transition-opacity hover:opacity-85"
        >
          {t(fallbackRedirect.lang, "fallback.continue")}
        </a>
      </section>
    </Layout>
  ) : article && ArticleContent ? (
    <Layout
      lang={article.post.data.locale}
      path={article.path}
      title={article.post.data.seoTitle ?? article.post.data.title}
      description={article.metaDescription}
      image={article.post.data.heroImage}
      ogType="article"
      jsonLd={article.jsonLd}
      alternates={article.alternates}
      dynamicGlass
    >
  <article aria-labelledby="article-title">
    <div
      class="relative mx-auto mt-10 w-[calc(100%-2rem)] max-w-3xl sm:w-[calc(100%-2.5rem)] md:w-[calc(100%-3rem)]"
    >
      <div
        class="post-card relative flex aspect-[3/4] flex-col overflow-hidden rounded-2xl md:aspect-[16/9] md:rounded-3xl"
        data-article-hero
        data-glass-card
      >
        <OptimizedPicture
          src={article.post.data.heroImage}
          alt={article.post.data.heroImageAlt}
          variant="articleHero"
          width={article.post.data.heroImageWidth}
          height={article.post.data.heroImageHeight}
          priority
          decoding="async"
          class="absolute inset-0 h-full w-full object-cover object-center transition-transform duration-700 ease-out"
        />
        <div
          class="absolute inset-0 bg-gradient-to-t from-black/75 via-black/15 to-transparent"
        >
        </div>
        <div
          class="post-card__content absolute z-10 right-1.5 bottom-1.5 left-1.5 flex flex-col justify-end rounded-2xl p-4 text-white sm:p-5"
          data-glass-target
        >
          <div class="flex w-full flex-col gap-4 text-center">
            <h1
              id="article-title"
              class="line-clamp-3 text-xl font-semibold leading-tight tracking-tight"
              data-pagefind-meta="title"
            >
              {article.post.data.title}
            </h1>
            <div
              class="mb-1 flex w-full items-center justify-center gap-3 text-xs text-white/75"
            >
              <span
                class="card-meta-pill"
                data-category={article.categorySlug}
              >
                {article.categoryLabel}
              </span>
              <time
                datetime={article.post.data.pubDate.toISOString()}
                class="shrink-0 text-end"
                >{article.publishedLabel}</time
              >
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="mx-auto w-full max-w-6xl px-4 py-8 sm:px-5 md:px-6">
      <div class="relative mx-auto max-w-6xl">
        <div class="mx-auto w-full max-w-3xl">
          <ProseContent class="article-prose max-w-none" pagefindBody>
            <p class="sr-only" data-pagefind-ignore>
              {article.post.data.title}
              {article.post.data.description}
              Topics: {article.categoryLabel}, {article.tagLabels.join(", ")}.
            </p>
            <ArticleContent />
          </ProseContent>

          <footer class="article-footer mt-10" data-pagefind-ignore>
            <p class="text-xs leading-6 text-muted-foreground" data-article-meta>
              <time datetime={article.post.data.pubDate.toISOString()}
                >{article.publishedText}: {article.publishedLabel}</time
              >
              <span aria-hidden="true"> · </span>
              <time
                datetime={(
                  article.post.data.updatedDate ?? article.post.data.pubDate
                ).toISOString()}>{article.modifiedText}: {article.modifiedLabel}</time
              >
            </p>
            <div
              class="mt-8 flex items-center justify-between gap-5"
              data-article-attribution
            >
              <a
                href={`/${article.post.data.locale}/author/`}
                class="flex min-w-0 items-center gap-3 text-sm font-medium text-muted-foreground transition-opacity hover:opacity-75"
              >
                <OptimizedPicture
                  src={authorImage}
                  alt={article.author?.data.name ?? SITE_CONFIG.name}
                  variant="logo"
                  width={32}
                  height={32}
                  class="size-8 rounded-full object-cover ring-1 ring-border"
                />
                <span class="truncate">{article.author?.data.name ?? SITE_CONFIG.name}</span>
              </a>
              <a
                href={`/${article.post.data.locale}/category/${article.categorySlug}/`}
                class="inline-flex min-h-7 shrink-0 items-center justify-center rounded-full bg-muted px-3 py-1 text-xs font-semibold text-foreground transition-colors hover:bg-accent"
              >
                {article.categoryLabel}
              </a>
            </div>
          </footer>

        </div>

        {
          article.tocHeadings.length >= 3 && (
            <aside class="absolute inset-y-0 left-[calc(50%+26rem)] hidden w-56 xl:block">
              <TableOfContents
                lang={article.post.data.locale}
                headings={article.tocHeadings}
              />
            </aside>
          )
        }
      </div>

      {
        article.relatedPosts.length > 0 && (
          <section
            class="post-related-posts mx-auto mt-16 max-w-6xl"
            aria-labelledby="related-posts"
            data-pagefind-ignore
            data-related-posts
          >
            <h2 id="related-posts" class="sr-only">
              {t(article.post.data.locale, "post.relatedPosts")}
            </h2>
            <PostCardGrid
              posts={article.relatedPosts}
              columns="tablet-three"
              headingLevel={3}
              class="post-card-grid"
            />
          </section>
        )
      }
    </div>
  </article>
    </Layout>
  ) : null
}

<style>
  :global(.post-related-posts) :global(.post-card__content) {
    text-align: center;
  }

  :global(.post-related-posts) :global(.post-card__content > div:first-child) {
    justify-content: center;
  }
</style>
