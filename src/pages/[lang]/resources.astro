---
import Layout from "@/layouts/main.astro"
import PageSection from "@/components/layout/PageSection.astro"
import PageHeader from "@/components/layout/PageHeader.astro"
import ProseContent from "@/components/layout/ProseContent.astro"
import TableOfContents from "@/components/navigation/TableOfContents.astro"
import { LOCALES, type Locale } from "@/config/locales"
import { SITE_CONFIG } from "@/config/site"
import { render } from "astro:content"
import { getPage } from "@/utils/content"
import { t } from "@/utils/translations"

export async function getStaticPaths() {
  return LOCALES.map((lang) => ({ params: { lang }, props: { lang } }))
}

const { lang } = Astro.props as { lang: Locale }
const page = await getPage(lang, "resources")
const rendered = page ? await render(page) : undefined
const Content = page ? (await render(page)).Content : undefined
const headings = (rendered?.headings ?? [])
  .filter((h) => h.depth === 2 || h.depth === 3)
  .map((h) => ({
    ...h,
    depth: h.depth as 2 | 3,
  }));
const title = page?.data.title ?? t(lang, "footer.resources")
const description = page?.data.description ?? `${title} · ${SITE_CONFIG.name}`
---

<Layout lang={lang} path="/resources/" title={title} description={description}>
  <PageSection class="py-8">
    <PageHeader title={title} subtitle={description} class="search-header" />
    <div class="mx-auto grid max-w-5xl gap-8 lg:grid-cols-[minmax(0,1fr)_14rem]">
      <div class="text-base leading-8 text-foreground/80">
        <ProseContent class="max-w-none">
          {Content ? <Content /> : <p>{SITE_CONFIG.description}</p>}
        </ProseContent>
      </div>
      {headings.length > 0 && (
        <aside class="hidden lg:block">
          <TableOfContents lang={lang} headings={headings} />
        </aside>
      )}
    </div>
  </PageSection>
</Layout>
